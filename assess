function refreshModulePicker(){
  for(let m = 1; m <= 4; m++){
    const btn = document.querySelector(`.mod[data-module="${m}"]`);
    const c = state.completed[m];
    if(c){
      btn.classList.add("completed");
      btn.querySelector(`.completion-line[data-completion="${m}"]`).textContent =
        `✓ Done · ${c.score} / ${c.total} (${c.pct}%) · ${c.badge.split(' — ')[0]}`;
    } else {
      btn.classList.remove("completed");
      btn.querySelector(`.completion-line[data-completion="${m}"]`).textContent = "—";
    }
  }
  const allDone = [1,2,3,4].every(m => state.completed[m]);
  $("all-done-banner").classList.toggle("show", allDone);
  $("result-to-certificate").style.display = allDone ? "" : "none";
  // Tweak the back-to-modules hint
  const remaining = [1,2,3,4].filter(m => !state.completed[m]).length;
  $("back-to-modules-hint").textContent = allDone
    ? "You've done all four — head back to claim your certificate."
    : (remaining < 4
        ? `${remaining} module${remaining===1?'':'s'} to go. Head back and pick the next one — your other scores stay saved here.`
        : "Got another module to do? Head back and pick the next one — your other scores will be saved here.");
}

// Patch original show() so module picker refreshes whenever we visit it
const _origShow = show;
show = function(name){
  _origShow(name);
  if(name === "modules") refreshModulePicker();
  if(name === "certificate") renderCertificate();
};

function startQuiz(m){
  state.module = m;
  state.qIndex = 0;
  state.answers = [];
  state.score = 0;
  state.done = false;
  state.timedOut = false;
  $("score-of").textContent = MODULES[m].questions.length;
  $("prog-label").textContent = MODULES[m].name;
  $("prog-label-top").textContent = MODULES[m].name;
  renderQ();
  show("quiz");
  startTimer(MODULES[m].timeLimit);
}

function fmtMMSS(s){
  s = Math.max(0, s|0);
  const m = (s/60)|0, r = s%60;
  return (m<10?"0":"")+m+":"+(r<10?"0":"")+r;
}
function renderTimer(){
  $("timer-text").textContent = fmtMMSS(state.secondsLeft);
  const t = $("timer");
  t.classList.remove("warning","danger");
  if(state.secondsLeft <= 30) t.classList.add("danger");
  else if(state.secondsLeft <= 90) t.classList.add("warning");
}
function startTimer(seconds){
  stopTimer();
  state.secondsLeft = seconds;
  renderTimer();
  state.timerId = setInterval(() => {
    state.secondsLeft--;
    renderTimer();
    if(state.secondsLeft <= 0){
      stopTimer();
      handleTimeout();
    }
  }, 1000);
}
function stopTimer(){
  if(state.timerId){ clearInterval(state.timerId); state.timerId = null; }
}
function handleTimeout(){
  state.timedOut = true;
  const mod = MODULES[state.module];
  const answered = state.answers.length;
  const total = mod.questions.length;
  $("timeup-line").textContent = `The ${Math.round(mod.timeLimit/60)}-minute timer for ${mod.name} ran out. You answered ${answered} of ${total} questions. As a reminder, the assessment can't be paused or resumed — you'll need to start again from the beginning.`;
  $("overlay-timeup").classList.add("show");
}

$("timeup-restart").addEventListener("click", () => {
  $("overlay-timeup").classList.remove("show");
  // Reset state and bounce back to welcome
  state.module = null;
  state.qIndex = 0;
  state.answers = [];
  state.score = 0;
  state.done = false;
  state.timedOut = false;
  $("trainee-name").value = "";
  show("welcome");
});

// Shuffle helper (Fisher-Yates) — deterministic per-question so results match the feedback
function seededShuffle(arr, seed){
  const a = arr.slice();
  let s = seed;
  for(let i = a.length - 1; i > 0; i--){
    s = (s * 9301 + 49297) % 233280;
    const j = Math.floor((s / 233280) * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function arrEq(a, b){
  if(a.length !== b.length) return false;
  for(let i = 0; i < a.length; i++) if(a[i] !== b[i]) return false;
  return true;
}

// Per-question working state
let _qState = null;

function renderQ(){
  const mod = MODULES[state.module];
  const q = mod.questions[state.qIndex];
  $("q-number").textContent = "Question " + (state.qIndex+1);
  $("q-text").textContent = q.q;
  $("score-now").textContent = state.score;
  $("prog-count").textContent = (state.qIndex+1) + " / " + mod.questions.length;
  $("prog-bar").style.width = (((state.qIndex)/mod.questions.length)*100) + "%";
  const opts = $("q-opts"); opts.innerHTML = ""; opts.classList.remove("locked","multi");
  const fb = $("q-feedback"); fb.classList.remove("show","good","bad"); fb.innerHTML = "";
  const next = $("next-btn"); next.disabled = true;
  next.textContent = (state.qIndex === mod.questions.length - 1) ? "See my results →" : "Next →";
  const checkRow = $("check-row"); checkRow.classList.remove("show");
  const checkBtn = $("check-btn"); checkBtn.disabled = true;
  _qState = null;

  const type = q.type || 'mcq';
  if(type === 'mcq') renderMCQ(q);
  else if(type === 'tf') renderTF(q);
  else if(type === 'multi') renderMulti(q);
  else if(type === 'match') renderMatch(q);
  else if(type === 'order') renderOrder(q);
}

function showFeedback(ok, q){
  const fb = $("q-feedback");
  fb.classList.add("show", ok ? "good" : "bad");
  fb.innerHTML = (ok ? "<b>✓ Correct.</b> " : "<b>✗ Not quite.</b> ") + q.why;
  $("next-btn").disabled = false;
  $("q-opts").classList.add("locked");
  if(ok) state.score++;
  $("score-now").textContent = state.score;
}

/* ---------- MCQ (instant) ---------- */
function renderMCQ(q){
  const opts = $("q-opts");
  const letters = ["A","B","C","D","E","F"];
  q.options.forEach((opt, i) => {
    const div = document.createElement("button");
    div.className = "opt"; div.type = "button";
    div.innerHTML = `<span class="letter">${letters[i]}</span><span>${opt}</span>`;
    div.addEventListener("click", () => {
      if(opts.classList.contains("locked")) return;
      const allOpts = opts.querySelectorAll(".opt");
      allOpts.forEach((o, idx) => {
        o.setAttribute("disabled","true"); o.style.pointerEvents = "none";
        if(idx === q.a) o.classList.add("correct");
        if(idx === i && idx !== q.a) o.classList.add("wrong");
      });
      const ok = i === q.a;
      state.answers.push({ qIndex: state.qIndex, type:'mcq', picked: i, correct: q.a, ok });
      showFeedback(ok, q);
    });
    opts.appendChild(div);
  });
}

/* ---------- True/False (instant) ---------- */
function renderTF(q){
  const opts = $("q-opts");
  const row = document.createElement("div");
  row.className = "tf-row";
  [["True", true, "👍"], ["False", false, "👎"]].forEach(([label, val, ic]) => {
    const b = document.createElement("button");
    b.className = "tf-btn"; b.type = "button";
    b.dataset.val = val ? "T" : "F";
    b.innerHTML = `<span class="ic">${ic}</span>${label}`;
    b.addEventListener("click", () => {
      if(opts.classList.contains("locked")) return;
      const ok = val === q.a;
      [...row.children].forEach(c => {
        c.setAttribute("disabled","true"); c.style.pointerEvents = "none";
        const cVal = c.dataset.val === "T";
        if(cVal === q.a) c.classList.add("correct");
        if(c === b && !ok) c.classList.add("wrong");
      });
      state.answers.push({ qIndex: state.qIndex, type:'tf', picked: val, correct: q.a, ok });
      showFeedback(ok, q);
    });
    row.appendChild(b);
  });
  opts.appendChild(row);
}

/* ---------- Multi-select (check-then-grade) ---------- */
function renderMulti(q){
  const opts = $("q-opts");
  opts.classList.add("multi");
  const hint = document.createElement("div");
  hint.className = "multi-hint";
  hint.textContent = `Pick all that apply — there ${q.a.length===1?'is 1 correct answer':'are '+q.a.length+' correct answers'}.`;
  opts.appendChild(hint);
  _qState = { picks: new Set() };
  q.options.forEach((opt, i) => {
    const div = document.createElement("button");
    div.className = "opt"; div.type = "button";
    div.innerHTML = `<span class="letter"></span><span>${opt}</span>`;
    div.addEventListener("click", () => {
      if(opts.classList.contains("locked")) return;
      if(_qState.picks.has(i)){ _qState.picks.delete(i); div.classList.remove("picked"); }
      else { _qState.picks.add(i); div.classList.add("picked"); }
      $("check-btn").disabled = _qState.picks.size === 0;
    });
    opts.appendChild(div);
  });
  $("check-row").classList.add("show");
  $("check-btn").onclick = () => {
    const picked = [..._qState.picks].sort();
    const correct = q.a.slice().sort();
    const ok = arrEq(picked, correct);
    // mark correctness on each option
    opts.querySelectorAll(".opt").forEach((o, idx) => {
      o.setAttribute("disabled","true"); o.style.pointerEvents = "none";
      o.classList.remove("picked");
      const isPicked = picked.includes(idx);
      const isCorrect = correct.includes(idx);
      if(isCorrect) o.classList.add("correct");
      else if(isPicked) o.classList.add("wrong");
    });
    state.answers.push({ qIndex: state.qIndex, type:'multi', picked, correct, ok });
    showFeedback(ok, q);
    $("check-row").classList.remove("show");
  };
}

/* ---------- Matching ---------- */
function renderMatch(q){
  const opts = $("q-opts");
  const grid = document.createElement("div");
  grid.className = "match-grid";
  // Right values shuffled (deterministic by qIndex)
  const rights = q.pairs.map(p => p.r);
  const shuffled = seededShuffle(rights, state.module * 100 + state.qIndex);
  _qState = { picks: new Array(q.pairs.length).fill("") };
  q.pairs.forEach((p, i) => {
    const row = document.createElement("div");
    row.className = "match-row";
    const left = document.createElement("div");
    left.className = "match-left"; left.textContent = p.l;
    const arr = document.createElement("div");
    arr.className = "arr"; arr.textContent = "→";
    const sel = document.createElement("select");
    sel.className = "match-select";
    sel.innerHTML = `<option value="">— pick a match —</option>` + shuffled.map(r => `<option value="${escapeAttr(r)}">${escapeHtml(r)}</option>`).join("");
    sel.addEventListener("change", () => {
      _qState.picks[i] = sel.value;
      $("check-btn").disabled = _qState.picks.some(v => !v);
    });
    row.appendChild(left); row.appendChild(arr); row.appendChild(sel);
    grid.appendChild(row);
  });
  opts.appendChild(grid);
  $("check-row").classList.add("show");
  $("check-btn").onclick = () => {
    let allOk = true;
    grid.querySelectorAll(".match-row").forEach((row, i) => {
      const sel = row.querySelector(".match-select");
      sel.disabled = true;
      const correctR = q.pairs[i].r;
      if(_qState.picks[i] === correctR) row.classList.add("correct");
      else { row.classList.add("wrong"); allOk = false; }
    });
    state.answers.push({ qIndex: state.qIndex, type:'match', picked: _qState.picks.slice(), correct: q.pairs.map(p => p.r), ok: allOk });
    showFeedback(allOk, q);
    $("check-row").classList.remove("show");
  };
}

/* ---------- Ordering ---------- */
function renderOrder(q){
  const opts = $("q-opts");
  // pool (top) and your order (bottom)
  const wrap = document.createElement("div");
  const pool = document.createElement("div"); pool.className = "order-pool";
  const list = document.createElement("div"); list.className = "order-list";
  const poolLabel = document.createElement("div"); poolLabel.className = "order-label"; poolLabel.textContent = "Available items — click to add in order";
  const listLabel = document.createElement("div"); listLabel.className = "order-label"; listLabel.textContent = "Your order — click an item to send it back";
  // shuffle items by original index
  const idxOrder = q.items.map((_, i) => i);
  const shuffled = seededShuffle(idxOrder, state.module * 100 + state.qIndex + 7);
  _qState = { picked: [] };
  function renderState(){
    pool.innerHTML = ""; list.innerHTML = "";
    shuffled.forEach(idx => {
      if(_qState.picked.includes(idx)) return;
      const it = document.createElement("button");
      it.className = "order-item"; it.type = "button"; it.textContent = q.items[idx];
      it.addEventListener("click", () => {
        if(opts.classList.contains("locked")) return;
        _qState.picked.push(idx); renderState();
      });
      pool.appendChild(it);
    });
    _qState.picked.forEach((idx, pos) => {
      const it = document.createElement("button");
      it.className = "order-item"; it.type = "button";
      it.innerHTML = `<span class="pos">${pos+1}</span> ${q.items[idx]}`;
      it.addEventListener("click", () => {
        if(opts.classList.contains("locked")) return;
        _qState.picked.splice(pos, 1); renderState();
      });
      list.appendChild(it);
    });
    $("check-btn").disabled = _qState.picked.length !== q.items.length;
  }
  wrap.appendChild(poolLabel); wrap.appendChild(pool);
  wrap.appendChild(listLabel); wrap.appendChild(list);
  opts.appendChild(wrap);
  renderState();
  $("check-row").classList.add("show");
  $("check-btn").onclick = () => {
    const correct = q.items.map((_, i) => i);
    const ok = arrEq(_qState.picked, correct);
    // disable + mark
    list.querySelectorAll(".order-item").forEach((it, pos) => {
      it.classList.add("locked"); it.style.pointerEvents = "none";
      const idx = _qState.picked[pos];
      if(idx === pos) it.classList.add("correct");
      else it.classList.add("wrong");
    });
    pool.querySelectorAll(".order-item").forEach(it => { it.style.pointerEvents = "none"; it.style.opacity = ".5"; });
    state.answers.push({ qIndex: state.qIndex, type:'order', picked: _qState.picked.slice(), correct, ok });
    showFeedback(ok, q);
    $("check-row").classList.remove("show");
  };
}

function escapeAttr(s){
  return String(s).replace(/[&<>"']/g, (c)=>({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;" }[c]));
}

$("next-btn").addEventListener("click", () => {
  const mod = MODULES[state.module];
  if(state.qIndex < mod.questions.length - 1){
    state.qIndex++;
    renderQ();
  } else {
    finish();
  }
});

function finish(){
  state.done = true;
  stopTimer();
  const mod = MODULES[state.module];
  const total = mod.questions.length;
  const pct = Math.round((state.score / total) * 100);
  $("result-pct").textContent = pct + "%";
  $("result-line").textContent = mod.name + " · " + state.score + " / " + total + " correct";
  $("result-greeting").innerHTML = "Nicely done, <span class=\"accent\">"+escapeHtml(state.name.split(" ")[0])+"</span>!";
  // badges
  const b = $("result-badge"); b.innerHTML = "";
  let badge, blurb;
  if(pct === 100){ badge = "Gold — Legora Sensei 🥇"; blurb = "Perfect score. You're absolutely ready to deliver this module. Go forth and train."; b.className = "badge gold"; }
  else if(pct >= 80){ badge = "Silver — Trainer Ready 🥈"; blurb = "Strong understanding across the board. A quick reread of anything you missed and you're good to go."; b.className = "badge silver"; }
  else if(pct >= 60){ badge = "Bronze — Almost There 🥉"; blurb = "You've got the shape of it — worth a second pass over the bits you missed before you deliver the session."; b.className = "badge bronze"; }
  else { badge = "Have another look 📚"; blurb = "No drama — flag this with your enablement lead and rewatch the module before you deliver it."; b.className = "badge try"; }
  b.textContent = badge;
  $("result-blurb").textContent = blurb;

  // build the summary text (also used in emails)
  const lines = [];
  lines.push("LEGORA ENABLEMENT TRAINING — ASSESSMENT RESULT");
  lines.push("------------------------------------------------");
  lines.push("Name:      " + state.name);
  lines.push("Module:    " + mod.name);
  lines.push("Score:     " + state.score + " / " + total + "  (" + pct + "%)");
  lines.push("Rating:    " + badge);
  lines.push("Date:      " + new Date().toISOString().slice(0,10));
  lines.push("");
  lines.push("Answers:");
  state.answers.forEach((a, i) => {
    const q = mod.questions[i];
    const letters = ["A","B","C","D","E","F"];
    let pickedTxt = "", correctTxt = "";
    if(a.type === 'mcq'){ pickedTxt = letters[a.picked]; correctTxt = letters[a.correct]; }
    else if(a.type === 'tf'){ pickedTxt = a.picked ? "True" : "False"; correctTxt = a.correct ? "True" : "False"; }
    else if(a.type === 'multi'){ pickedTxt = a.picked.map(x => letters[x]).join(","); correctTxt = a.correct.map(x => letters[x]).join(","); }
    else if(a.type === 'match'){ pickedTxt = "matching"; correctTxt = a.ok ? "all paired" : "not all paired"; }
    else if(a.type === 'order'){ pickedTxt = "ordering"; correctTxt = a.ok ? "sequence right" : "sequence off"; }
    else { pickedTxt = String(a.picked); correctTxt = String(a.correct); }
    lines.push("  Q" + (i+1) + " [" + (a.type||'mcq') + "]  " + (a.ok ? "✓" : "✗") + "  Picked " + pickedTxt + "  ·  Correct: " + correctTxt);
    lines.push("       " + q.q);
  });
  lines.push("");
  lines.push("— Sent automatically from the LET Assessment widget.");
  $("result-summary").textContent = lines.join("\n");

  // Record completion for stamp + certificate
  state.completed[state.module] = {
    score: state.score,
    total,
    pct,
    badge,
    dateISO: new Date().toISOString().slice(0,10),
  };

  show("results");
}

// Back to modules from results
$("back-to-modules").addEventListener("click", () => {
  // wipe per-quiz state but keep name + completed map
  state.module = null;
  state.qIndex = 0;
  state.answers = [];
  state.score = 0;
  state.done = false;
  state.timedOut = false;
  stopTimer();
  show("modules");
});

// Certificate buttons
$("result-to-certificate").addEventListener("click", () => show("certificate"));
$("see-certificate").addEventListener("click", () => show("certificate"));
$("cert-back").addEventListener("click", () => show("modules"));
$("cert-print").addEventListener("click", () => window.print());

function renderCertificate(){
  $("cert-name").textContent = state.name || "—";
  $("cert-date").textContent = new Date().toISOString().slice(0,10);
  const grid = $("cert-scores");
  grid.innerHTML = "";
  let totalPct = 0;
  for(let m = 1; m <= 4; m++){
    const c = state.completed[m] || {};
    const mod = MODULES[m];
    const card = document.createElement("div");
    card.className = "cert-score";
    const pct = c.pct ?? "—";
    if(c.pct != null) totalPct += c.pct;
    card.innerHTML = `<span class="mn">${mod.name}</span><span class="sn">${c.score ?? "—"} / ${c.total ?? mod.questions.length} · ${pct}${c.pct!=null?'%':''} · ${c.badge ? c.badge.split(' — ')[0] : '—'}</span>`;
    grid.appendChild(card);
  }
  const overall = Math.round(totalPct / 4);
  let verdict;
  if(overall === 100) verdict = "🪙 Verdict: Legora Sensei. Get a cape made.";
  else if(overall >= 90) verdict = "🌟 Verdict: Trainer of considerable repute. Earned.";
  else if(overall >= 80) verdict = "✨ Verdict: Solidly Trainer-Ready. Go forth.";
  else if(overall >= 70) verdict = "🌿 Verdict: Capable enabler. Bring notes.";
  else verdict = "📚 Verdict: Have a quick rewatch of the rocky bits, then go forth bravely.";
  $("cert-verdict").textContent = verdict + "  ·  Overall: " + overall + "%";
}

function buildMailtoArtefacts(){
  const mod = MODULES[state.module];
  const total = mod.questions.length;
  const pct = Math.round((state.score / total) * 100);
  const subject = "[LET Assessment] " + state.name + " · " + mod.name + " · " + state.score + "/" + total + " (" + pct + "%)";
  const body = $("result-summary").textContent;
  return { subject, body };
}
function openMailto(to, subject, body){
  const href = "mailto:" + encodeURIComponent(to) + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
  const a = document.createElement("a");
  a.href = href; a.target = "_blank"; a.rel = "noopener";
  a.style.display = "none";
  document.body.appendChild(a);
  a.click();
  setTimeout(() => a.remove(), 100);
}
$("send-emails").addEventListener("click", () => {
  const email = $("trainee-email").value.trim();
  const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  if(!isValid){ $("email-err").classList.add("show"); return; }
  $("email-err").classList.remove("show");
  state.email = email;
  $("show-trainee-email").textContent = email;
  $("show-tracker-email").textContent = TRACKER_EMAIL;

  const { subject, body } = buildMailtoArtefacts();
  openMailto(state.email, subject, body);
  // Stagger the tracker mailto — some mail clients drop back-to-back triggers
  setTimeout(() => openMailto(TRACKER_EMAIL, subject, body), 600);
});

$("copy-results").addEventListener("click", async () => {
  const { subject, body } = buildMailtoArtefacts();
  const recipients = (state.email || "your email") + ", " + TRACKER_EMAIL;
  const text = "To: " + recipients + "\nSubject: " + subject + "\n\n" + body;
  try {
    await navigator.clipboard.writeText(text);
    const b = $("copy-results"); const orig = b.textContent;
    b.textContent = "✅ Copied"; setTimeout(() => b.textContent = orig, 1800);
  } catch(e){
    alert("Couldn't copy automatically — selecting the summary text below instead.");
    const sel = window.getSelection(); sel.removeAllRanges();
    const r = document.createRange(); r.selectNode($("result-summary")); sel.addRange(r);
  }
});

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, (c)=>({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;" }[c]));
}

// Anti-restart safety: warn on tab close mid-quiz
window.addEventListener("beforeunload", (e) => {
  if($("panel-quiz").classList.contains("active") && !state.done){
    e.preventDefault();
    e.returnValue = "Your assessment is in progress — leaving will lose your answers.";
    return e.returnValue;
  }
});
</script>
