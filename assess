<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Legora Enablement Training — Assessment</title>
<style>
  :root{
    --bg:#f4faf5;
    --bg-2:#ffffff;
    --ink:#0e2c1e;
    --muted:#5b7b6a;
    --line:#dbeadf;
    --brand:#2bbd6a;
    --brand-2:#19a35a;
    --accent:#0e6b3a;
    --good:#1ea65d;
    --bad:#e25555;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:radial-gradient(1200px 800px at 10% -10%, #d6f0de 0%, transparent 60%), radial-gradient(1000px 700px at 110% 110%, #e9f7ee 0%, transparent 55%), var(--bg);color:var(--ink);font-family:"Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;min-height:100vh;}
  .wrap{max-width:780px;margin:0 auto;padding:32px 22px 80px;}
  .brand{display:flex;align-items:center;gap:12px;font-weight:700;letter-spacing:.4px;font-size:14px;color:var(--muted);text-transform:uppercase;}
  .brand .dot{width:10px;height:10px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--brand-2));box-shadow:0 0 18px var(--brand);}
  h1{font-size:34px;line-height:1.15;margin:18px 0 10px;font-weight:800;letter-spacing:-.5px}
  h1 .accent{background:linear-gradient(90deg,var(--brand-2),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;}
  h2{font-size:22px;margin:0 0 12px;font-weight:700}
  p{color:var(--muted);line-height:1.55;}
  .card{background:#ffffff;border:1px solid var(--line);border-radius:18px;padding:26px;box-shadow:0 8px 28px -18px rgba(14,44,30,.18);}
  .panel{display:none}
  .panel.active{display:block;animation:fade .35s ease}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  label{display:block;font-size:13px;color:var(--muted);margin:14px 0 6px;text-transform:uppercase;letter-spacing:.5px}
  input[type=text],input[type=email]{width:100%;padding:14px 16px;border-radius:12px;border:1px solid var(--line);background:#fbfffc;color:var(--ink);font-size:16px;outline:none;transition:border .2s, box-shadow .2s}
  input:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(31,122,77,.3)}
  .btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--brand),var(--brand-2));color:white;border:none;border-radius:999px;padding:14px 22px;font-weight:700;font-size:15px;cursor:pointer;box-shadow:0 10px 30px -10px rgba(31,122,77,.55);transition:transform .15s ease, box-shadow .15s ease}
  .btn:hover{transform:translateY(-1px);box-shadow:0 14px 36px -10px rgba(95,212,154,.45)}
  .btn:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
  .btn.secondary{background:#ffffff;box-shadow:none;border:1px solid var(--line);color:var(--ink)}
  .row{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
  .modules{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:22px}
  @media (max-width:620px){.modules{grid-template-columns:1fr}}
  .mod{cursor:pointer;border:1px solid var(--line);border-radius:16px;padding:18px;background:#ffffff;transition:border .2s, transform .15s, background .2s, box-shadow .2s;text-align:left;box-shadow:0 4px 16px -12px rgba(14,44,30,.18);}
  .mod:hover{border-color:var(--brand);transform:translateY(-2px);background:rgba(95,212,154,.07)}
  .mod .num{font-size:12px;letter-spacing:1.4px;color:var(--brand-2);font-weight:700;text-transform:uppercase}
  .mod .title{font-size:17px;font-weight:700;margin:4px 0 6px}
  .mod .desc{font-style:italic;color:var(--muted);font-size:13px;line-height:1.4}
  .rules{margin:18px 0 0;padding:16px 18px;border-radius:12px;background:#eef9f1;border:1px solid #cce6d4}
  .rules h3{margin:0 0 8px;font-size:13px;letter-spacing:1px;color:var(--accent);text-transform:uppercase}
  .rules ul{margin:0;padding-left:18px;color:var(--ink);font-size:14px;line-height:1.7}
  .progress{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted);letter-spacing:1.2px;text-transform:uppercase;margin-bottom:14px}
  .bar{flex:1;height:6px;background:#e3efe7;border-radius:999px;overflow:hidden}
  .bar > i{display:block;height:100%;background:linear-gradient(90deg,var(--brand),var(--brand-2));transition:width .35s ease;border-radius:999px}
  .qnum{font-size:13px;color:var(--brand-2);letter-spacing:1.6px;font-weight:700;text-transform:uppercase;margin-bottom:4px}
  .q{font-size:22px;font-weight:700;line-height:1.3;margin-bottom:22px}
  .opts{display:flex;flex-direction:column;gap:10px;margin-bottom:8px}
  .opt{cursor:pointer;border:1px solid var(--line);border-radius:14px;padding:14px 16px;background:#fbfffc;display:flex;gap:12px;align-items:flex-start;transition:border .15s, background .15s, transform .12s}
  .opt:hover{border-color:var(--brand);background:rgba(95,212,154,.06)}
  .opt .letter{width:28px;height:28px;border-radius:50%;background:#e8f3ec;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex:0 0 28px;color:var(--ink)}
  .opt.selected{border-color:var(--brand);background:rgba(95,212,154,.15)}
  .opt.correct{border-color:var(--good);background:#e6f7ed}
  .opt.correct .letter{background:var(--good);color:#ffffff}
  .opt.wrong{border-color:var(--bad);background:#fdebeb}
  .opt.wrong .letter{background:var(--bad);color:#ffffff}
  .opt[disabled]{cursor:default}
  .feedback{margin-top:14px;padding:12px 14px;border-radius:12px;font-size:14px;line-height:1.5;display:none}
  .feedback.show{display:block;animation:fade .25s ease}
  .feedback.good{background:#e6f7ed;border:1px solid #b6e5c4;color:#0e4a2a}
  .feedback.bad{background:#fdebeb;border:1px solid #f3c6c6;color:#7a1f1f}
  .nav{display:flex;justify-content:space-between;align-items:center;margin-top:18px}
  .score-pill{font-size:13px;font-weight:700;color:var(--muted);background:#ffffff;border:1px solid var(--line);padding:8px 14px;border-radius:999px}
  .score-pill b{color:var(--accent)}
  .reveal{font-size:48px;font-weight:800;letter-spacing:-1px;text-align:center;margin:8px 0 0}
  .reveal .pct{background:linear-gradient(90deg,var(--brand-2),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;font-size:96px;display:block;line-height:1}
  .badge{display:inline-block;padding:8px 16px;border-radius:999px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;font-size:12px;margin-top:14px}
  .badge.gold{background:linear-gradient(135deg,#bdf09a,#2bbd6a);color:#0a1a0e}
  .badge.silver{background:linear-gradient(135deg,#cfe4d6,#5b7b6a);color:#06140f}
  .badge.bronze{background:linear-gradient(135deg,#e0b88a,#a06a35);color:#1a0a05}
  .badge.try{background:#f0f6f2;color:var(--ink);border:1px solid var(--line)}
  .summary{margin:20px 0;padding:18px;border:1px solid var(--line);border-radius:14px;background:#f7fbf8;font-size:14px;line-height:1.6;color:var(--muted);white-space:pre-wrap;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px;max-height:240px;overflow:auto;text-align:left}
  .center{text-align:center}
  .small{font-size:13px;color:var(--muted)}
  .err{color:#9a2929;font-size:13px;margin-top:6px;display:none}
  .err.show{display:block}
  .footer{margin-top:30px;text-align:center;font-size:12px;color:var(--muted);letter-spacing:.6px}
  .lock{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);background:#ffffff;padding:6px 12px;border-radius:999px;border:1px solid var(--line)}
  .mod-meta{display:flex;justify-content:space-between;align-items:center;margin-top:10px}
  .mod-meta .tag{font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}
  /* Timer */
  .timer-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:10px;flex-wrap:wrap}
  .timer{font-variant-numeric:tabular-nums;font-weight:700;font-size:15px;background:#ffffff;border:1px solid var(--line);border-radius:999px;padding:8px 14px;display:inline-flex;align-items:center;gap:8px;color:var(--ink)}
  .timer .ico{width:8px;height:8px;border-radius:50%;background:var(--good)}
  .timer.warning{background:#fff5e6;border-color:#f4c987;color:#7a4a0c}
  .timer.warning .ico{background:#e69b1a}
  .timer.danger{background:#fdebeb;border-color:#f3c6c6;color:#7a1f1f;animation:pulse 1s ease-in-out infinite}
  .timer.danger .ico{background:var(--bad)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.55}}
  /* Time-up overlay */
  .overlay{position:fixed;inset:0;background:rgba(14,44,30,.55);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:24px;z-index:50}
  .overlay.show{display:flex;animation:fade .25s ease}
  .overlay .modal{background:#fff;border-radius:18px;padding:28px;max-width:480px;width:100%;text-align:center;box-shadow:0 24px 60px -20px rgba(14,44,30,.45);border:1px solid var(--line)}
  .overlay .modal h2{margin:6px 0 8px;font-size:24px}
  .overlay .modal p{color:var(--muted);margin:0 0 18px}
  .overlay .modal .emoji{font-size:42px;line-height:1}

  /* True/False */
  .tf-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:8px}
  @media (max-width:520px){.tf-row{grid-template-columns:1fr}}
  .tf-btn{cursor:pointer;border:2px solid var(--line);border-radius:14px;padding:22px;background:#fbfffc;font-weight:800;font-size:20px;color:var(--ink);transition:border .15s, background .15s, transform .12s}
  .tf-btn:hover{border-color:var(--brand);background:rgba(95,212,154,.07);transform:translateY(-1px)}
  .tf-btn .ic{font-size:30px;display:block;margin-bottom:6px}
  .tf-btn.correct{border-color:var(--good);background:#e6f7ed;color:#0e4a2a}
  .tf-btn.wrong{border-color:var(--bad);background:#fdebeb;color:#7a1f1f}
  .tf-btn[disabled]{cursor:default}

  /* Multi-select */
  .multi-hint{font-size:12px;color:var(--muted);margin:-4px 0 10px;font-style:italic}
  .multi .opt .letter{background:transparent;border:2px solid var(--line);width:22px;height:22px;flex:0 0 22px;font-size:11px;color:transparent}
  .multi .opt.picked{border-color:var(--brand);background:rgba(95,212,154,.1)}
  .multi .opt.picked .letter{background:var(--brand);border-color:var(--brand);color:#fff}
  .multi .opt.picked .letter::after{content:"✓"}

  /* Matching */
  .match-grid{display:flex;flex-direction:column;gap:10px;margin-bottom:8px}
  .match-row{display:grid;grid-template-columns:1fr 14px 1.3fr;align-items:center;gap:10px}
  @media (max-width:520px){.match-row{grid-template-columns:1fr;gap:6px}.match-row .arr{display:none}}
  .match-left{padding:10px 14px;background:#fff;border:1px solid var(--line);border-radius:10px;font-weight:600;font-size:14px}
  .match-row .arr{color:var(--muted);text-align:center}
  .match-select{padding:10px 12px;border-radius:10px;border:1px solid var(--line);background:#fff;color:var(--ink);font-size:14px;cursor:pointer;width:100%}
  .match-select:focus{border-color:var(--brand);outline:none}
  .match-row.correct .match-select{border-color:var(--good);background:#e6f7ed}
  .match-row.wrong .match-select{border-color:var(--bad);background:#fdebeb}

  /* Ordering */
  .order-label{font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--muted);margin:4px 0}
  .order-pool, .order-list{display:flex;flex-wrap:wrap;gap:8px;padding:12px;border:1px dashed var(--line);border-radius:12px;background:#fbfffc;min-height:60px;margin-bottom:10px}
  .order-list{background:#f3fbf6;border-style:solid;border-color:var(--line)}
  .order-item{cursor:pointer;border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 14px;font-size:14px;font-weight:600;transition:border .15s, background .15s, transform .12s;display:inline-flex;align-items:center;gap:8px}
  .order-item:hover{border-color:var(--brand);transform:translateY(-1px)}
  .order-list .order-item .pos{background:var(--brand);color:#fff;width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:800;display:inline-flex;align-items:center;justify-content:center}
  .order-item.locked{cursor:default}
  .order-item.correct{border-color:var(--good);background:#e6f7ed}
  .order-item.wrong{border-color:var(--bad);background:#fdebeb}

  /* Check button — shown for non-instant types */
  .check-row{margin-top:6px;display:none}
  .check-row.show{display:block}
  .check-row .btn{width:100%}

  /* Completion stamps on module picker */
  .mod{position:relative;overflow:hidden}
  .mod.completed{border-color:var(--brand);background:#f3fbf6}
  .mod.completed .num{color:var(--brand-2)}
  .mod .stamp{display:none;position:absolute;top:14px;right:14px;border:2px solid var(--brand);color:var(--brand);font-weight:800;font-size:10px;letter-spacing:1.4px;text-transform:uppercase;padding:5px 9px;border-radius:6px;transform:rotate(8deg);background:rgba(255,255,255,.85);line-height:1}
  .mod.completed .stamp{display:inline-block}
  .mod .completion-line{display:none;margin-top:8px;font-size:12px;font-weight:700;color:var(--brand)}
  .mod.completed .completion-line{display:block}

  /* All-done banner on module picker */
  .all-done-banner{margin:18px 0 0;padding:18px 20px;border-radius:14px;background:linear-gradient(135deg,#e8f7ee,#d6f0de);border:1px solid var(--brand);display:none;align-items:center;gap:14px;flex-wrap:wrap;justify-content:space-between}
  .all-done-banner.show{display:flex}
  .all-done-banner .text{flex:1;min-width:220px}
  .all-done-banner h3{margin:0 0 4px;color:var(--accent)}
  .all-done-banner p{margin:0;font-size:13px}

  /* Certificate */
  .cert-frame{position:relative;background:linear-gradient(180deg,#fbfffc,#f1faf4);border:2px solid var(--brand);border-radius:18px;padding:36px 32px;text-align:center;box-shadow:0 24px 60px -28px rgba(14,44,30,.22)}
  .cert-frame::before,.cert-frame::after{content:"";position:absolute;width:42px;height:42px;border:2px solid var(--brand-2);opacity:.6}
  .cert-frame::before{top:10px;left:10px;border-right:0;border-bottom:0;border-top-left-radius:10px}
  .cert-frame::after{bottom:10px;right:10px;border-left:0;border-top:0;border-bottom-right-radius:10px}
  .cert-eyebrow{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--brand-2);font-weight:700}
  .cert-title{font-size:30px;margin:8px 0 4px;font-weight:800;letter-spacing:-.5px;line-height:1.2}
  .cert-sub{font-size:14px;color:var(--muted);margin:0 0 18px;font-style:italic}
  .cert-name{font-size:36px;font-weight:800;background:linear-gradient(90deg,var(--brand),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;letter-spacing:-.5px;margin:6px 0 6px;font-family:"Georgia",serif;font-style:italic}
  .cert-body{font-size:15px;line-height:1.65;color:var(--ink);text-align:left;margin:14px 0;padding:0 8px}
  .cert-body p{margin:0 0 10px;color:var(--ink)}
  .cert-scores{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:16px 0}
  @media (max-width:520px){.cert-scores{grid-template-columns:1fr}}
  .cert-score{padding:10px 12px;border:1px solid var(--line);border-radius:10px;background:#ffffff;text-align:left;font-size:13px}
  .cert-score .mn{display:block;font-weight:700;color:var(--ink)}
  .cert-score .sn{color:var(--muted);font-size:12px}
  .cert-seal{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;width:130px;height:130px;border:3px double var(--brand);border-radius:50%;margin:10px auto 8px;color:var(--brand);text-align:center;line-height:1.15;font-weight:800;letter-spacing:1px;text-transform:uppercase;font-size:10px;background:rgba(255,255,255,.6);transform:rotate(-6deg)}
  .cert-seal .big{font-size:24px;letter-spacing:0;text-transform:none;font-family:"Georgia",serif;font-style:italic;font-weight:700;margin:4px 0}
  .cert-foot{font-size:12px;color:var(--muted);margin-top:14px;font-style:italic}
  @media print{
    body{background:#fff !important}
    .wrap{padding:0 !important;max-width:100% !important}
    section.panel:not(#panel-certificate){display:none !important}
    .row,.brand,.footer{display:none !important}
    .cert-frame{border-color:#0b6c39;box-shadow:none}
  }
</style>
</head>
<body>
<div class="wrap">

<!-- ============ WELCOME ============ -->
<section id="panel-welcome" class="panel active">
  <div class="brand"><span class="dot"></span> Legora Enablement Training</div>
  <h1>LET <span class="accent">Assessment</span></h1>
  <p>Welcome — and congrats on completing a Legora Enablement Training (LET) module. This is a short, fun checkpoint to confirm that what was taught actually landed, and that you're equipped to go off and deliver this training yourself.</p>
  <div class="card" style="margin-top:18px">
    <h2>How it works</h2>
    <p>Pick the module you just finished. You'll be asked between 8 and 15 questions — a mix of multiple choice, true/false, "pick all that apply", matching pairs, and putting things in order — designed to take you 5–15 minutes. The questions test your <em>understanding</em> of Legora, not your memory of specific numbers or definitions, so think rather than recall. At the end you'll get a score, a fun rating, and two pre-filled emails — one to yourself, one to the enablement team. Finish all four and a witty certificate of Legora deputisation is yours.</p>
    <p style="font-size:13px;font-style:italic;color:var(--muted);margin-top:-6px">A heads-up on length: Module 1 is 10 questions, Module 4 is 8. Modules 2 (Legora Foundations) and 3 (Advanced Features) run longer — 12 and 15 — because they cover the most ground across the Assistant's source types, Tabular Review, the Word Add-In, Editor, Word Edits, Workflows and Playbooks. They earn the extra few minutes.</p>
    <div class="rules">
      <h3>Four rules</h3>
      <ul>
        <li>Once you start, <b>you can't go back to change an answer</b>.</li>
        <li>You can't pause or resume — give each question your best shot.</li>
        <li><b>Each module has a time limit</b> (8–12 minutes). If it runs out, the assessment ends and you have to start again from the beginning.</li>
        <li>Have fun. This isn't pass/fail — it's a confidence check.</li>
      </ul>
    </div>
    <label for="trainee-name">Your name</label>
    <input id="trainee-name" type="text" placeholder="e.g. Alex Morgan" autocomplete="name" />
    <div id="name-err" class="err">Please enter your name to continue.</div>
    <div class="row">
      <button class="btn" id="to-modules">Choose a module →</button>
    </div>
  </div>
</section>

<!-- ============ MODULE PICKER ============ -->
<section id="panel-modules" class="panel">
  <div class="brand"><span class="dot"></span> Pick the module you just finished</div>
  <h1>Which module <span class="accent">did you just complete?</span></h1>
  <p>Each assessment covers one module. Choose the one you've just been trained on — what's in italics underneath is a one-line reminder of what that session was about.</p>

  <div class="modules">
    <button class="mod" data-module="1">
      <span class="stamp">✓ Done</span>
      <div class="num">Module 1</div>
      <div class="title">AI Foundations</div>
      <div class="desc">Foundational principles of GenAI and LLMs — probabilistic vs deterministic, tokens, context windows, hallucination, and the engine-vs-car mental model.</div>
      <div class="completion-line" data-completion="1">—</div>
      <div class="mod-meta"><span class="tag">⏱ 10 min limit</span><span class="tag">10 questions</span></div>
    </button>
    <button class="mod" data-module="2">
      <span class="stamp">✓ Done</span>
      <div class="num">Module 2</div>
      <div class="title">Legora Foundations</div>
      <div class="desc">The core Legora features — Assistant (Sources + Create), Tabular Review, and the Word Add-In — how they work and when to use which.</div>
      <div class="completion-line" data-completion="2">—</div>
      <div class="mod-meta"><span class="tag">⏱ 12 min limit</span><span class="tag">12 questions</span></div>
    </button>
    <button class="mod" data-module="3">
      <span class="stamp">✓ Done</span>
      <div class="num">Module 3</div>
      <div class="title">Advanced Features</div>
      <div class="desc">End-to-end Workflows, Playbooks, Editor &amp; Word Edits, plus the KERNEL prompting framework and the six single-action step types.</div>
      <div class="completion-line" data-completion="3">—</div>
      <div class="mod-meta"><span class="tag">⏱ 15 min limit</span><span class="tag">15 questions</span></div>
    </button>
    <button class="mod" data-module="4">
      <span class="stamp">✓ Done</span>
      <div class="num">Module 4</div>
      <div class="title">Use Case Discovery</div>
      <div class="desc">What makes a good (and bad) use case, the three levels of use-case maturity, design thinking and the impact/effort matrix for prioritisation.</div>
      <div class="completion-line" data-completion="4">—</div>
      <div class="mod-meta"><span class="tag">⏱ 8 min limit</span><span class="tag">8 questions</span></div>
    </button>
  </div>

  <div class="all-done-banner" id="all-done-banner">
    <div class="text">
      <h3>🎉 All four modules done</h3>
      <p>You've completed the full LET. Claim your certificate of Legora deputisation — it's witty, weirdly official, and yours to print.</p>
    </div>
    <button class="btn" id="see-certificate">🏆 See my certificate →</button>
  </div>

  <div class="row" style="margin-top:24px">
    <span class="lock">🔒 Once you click a module, the quiz begins — no back button</span>
  </div>
</section>

<!-- ============ QUIZ ============ -->
<section id="panel-quiz" class="panel">
  <div class="timer-row">
    <span class="timer" id="timer"><span class="ico"></span><span id="timer-text">--:--</span></span>
